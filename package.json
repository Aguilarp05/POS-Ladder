{
  "name": "ladder",
  "version": "1.0.0",
  "description": "POS system for restaurants built with React + Electron",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.ladder.pos",
    "productName": "Ladder",
    "directories": { "output": "dist-electron" },
    "files": [
      "dist/**",
      "electron/**",
      "assets/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/Ladder_logo.ico"
    },
    "mac": {
      "target": "dmg",
      "identity": null
    },
    "linux": {
      "target": "AppImage"
    }
  }
}